# Secrets and local config — recipients must never commit these
wrangler.toml
wrangler.toml.audit
.dev.vars
.env
.env.*

# Defensive: credential material that must never land in the repo
# (service-account JSON keys, private keys, exported secrets)
*.pem
*.key
*-key.json
*service-account*.json
*credentials*.json
gcal_key*.txt
.cf-tracking-token

# Cloudflare build artifacts
.wrangler/
.cloudflare/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Node (if a recipient adds any tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
